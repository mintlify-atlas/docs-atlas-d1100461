  "keyFeatures": [
    "High-precision planetary position calculations using JPL ephemeris data",
    "Solar and lunar eclipse computations with geographic locations",
    "Multiple astrological house system support (Placidus, Koch, etc.)",
    "Fixed star positions with proper motion corrections",
    "Sidereal and tropical zodiac calculations with multiple ayanamsas",
    "Date and time conversion functions (Julian day, calendar systems)",
    "Rise, set, and transit time calculations for celestial objects",
    "Heliacal rising and setting phenomena computations"
  ],
  "publicApiSurface": [
    "swe_calc() - Calculate planetary positions",
    "swe_calc_ut() - Calculate positions with Universal Time",
    "swe_fixstar() - Calculate fixed star positions",
    "swe_houses() - Calculate house cusps and angles",
    "swe_sol_eclipse_when_glob() - Find next solar eclipse globally",
    "swe_lun_eclipse_when() - Find next lunar eclipse",
    "swe_rise_trans() - Calculate rise, set, and transit times",
    "swe_julday() - Convert calendar date to Julian day",
    "swe_revjul() - Convert Julian day to calendar date",
    "swe_set_ephe_path() - Set ephemeris file directory",
    "swe_set_sid_mode() - Set sidereal mode and ayanamsa",
    "swe_get_ayanamsa() - Get ayanamsa value",
    "swe_cotrans() - Transform coordinates",
    "swe_deltat() - Calculate Delta T",
    "swe_close() - Close Swiss Ephemeris and free resources"
  ]
}
